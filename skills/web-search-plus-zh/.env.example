# ============================================================================
# Web Search Plus — API 密钥配置
# ============================================================================
# 复制此文件为 .env 并填入你的密钥。
# 只需为你想用的提供商配置密钥。
#
# 快速设置：
#   cp .env.example .env
#   # 编辑 .env 填入你的密钥
#   source .env  # 将导出加载到当前 shell
#
# 重要：密钥必须使用 'export' 前缀，Python 才能读取！
# ============================================================================

# ----------------------------------------------------------------------------
# SERPER — Google 搜索 API
# ----------------------------------------------------------------------------
# 擅长：产品、购物、本地、快速查询、新闻、图片
#
# 获取密钥：
#   1. 访问 https://serper.dev
#   2. 注册（邮箱或 Google）
#   3. 从控制台复制 API 密钥
#
# 定价：
#   - 免费：2,500 次查询（一次性）
#   - Starter：$50/月 50,000 次查询
#   - Standard：$75/月 100,000 次查询
#
# 费用：约 $0.001/次（付费套餐）
# ----------------------------------------------------------------------------
export SERPER_API_KEY=

# ----------------------------------------------------------------------------
# TAVILY — AI 研究搜索
# ----------------------------------------------------------------------------
# 擅长：研究、深度挖掘、合成答案、完整页面内容
#
# 获取密钥：
#   1. 访问 https://tavily.com
#   2. 注册并验证邮箱
#   3. 进入 API Keys 部分
#   4. 生成并复制密钥
#
# 定价：
#   - 免费：1,000 次/月
#   - Basic：$5/月 1,000 次
#   - Pro：$40/月 10,000 次
#
# 费用：约 $0.004/次（付费套餐）
# ----------------------------------------------------------------------------
export TAVILY_API_KEY=

# ----------------------------------------------------------------------------
# EXA — 神经/语义搜索
# ----------------------------------------------------------------------------
# 擅长：语义查询、相似页面、公司发现、论文
#
# 获取密钥：
#   1. 访问 https://exa.ai
#   2. 注册（邮箱或 Google）
#   3. 进入控制台的 API 部分
#   4. 复制 API 密钥
#
# 定价：
#   - 免费：1,000 次/月
#   - 按量付费：约 $0.001/次
#
# 费用：约 $0.001/次
# ----------------------------------------------------------------------------
export EXA_API_KEY=

# ----------------------------------------------------------------------------
# YOU.COM — LLM 就绪的 Web 和新闻搜索
# ----------------------------------------------------------------------------
# 擅长：RAG 应用、实时资讯、网络+新闻合一体、AI 上下文
#
# 获取密钥：
#   1. 访问 https://api.you.com
#   2. 注册并创建账户
#   3. 从控制台生成 API 密钥
#
# 定价：
#   - 免费：有限查询用于测试
#   - 按量付费：约 $0.001/次
#   - 企业版：自定义定价
#
# 主要特性：
#   - LLM 优化摘要（无需解析）
#   - 网络 + 新闻统一一次调用
#   - 实时爬取完整页面内容
#   - 自动新闻分类
#
# 费用：约 $0.001/次
# ----------------------------------------------------------------------------
export YOU_API_KEY=

# ----------------------------------------------------------------------------
# SEARXNG — 隐私优先自托管元搜索
# ----------------------------------------------------------------------------
# 擅长：保护隐私的搜索、多源聚合、$0 API 费用
#
# 搭建你的实例：
#   1. 参见 https://docs.searxng.org/admin/installation.html
#   2. 最简单的方式：docker run -d -p 8080:8080 searxng/searxng
#   3. 在 settings.yml 中启用 JSON 格式：
#        search:
#          formats: [html, json]
#   4. 在下方设置你的实例 URL
#
# 定价：
#   - 免费（自托管）— 仅托管费用（VPS 约 $5/月）
#   - 无限查询
#
# 主要特性：
#   - 无追踪、无画像（隐私优先）
#   - 聚合 70+ 搜索引擎（Google、Bing、DuckDuckGo 等）
#   - 完全掌控你的搜索基础设施
#   - $0 API 费用
#
# 示例 URL：
#   - http://localhost:8080（本地 Docker）
#   - https://searx.your-domain.com（自托管）
#
# 注意：大多数公共 SearXNG 实例禁用了 JSON API！
#       你必须运行自己的实例。
# ----------------------------------------------------------------------------
export SEARXNG_INSTANCE_URL=

# ============================================================================
# 可选：默认提供商
# ============================================================================
# 设置此项以在未指定 --provider 时自动使用某个提供商
# （尚未在 search.py 中实现，但对包装脚本有用）
# ----------------------------------------------------------------------------
# DEFAULT_SEARCH_PROVIDER=serper
